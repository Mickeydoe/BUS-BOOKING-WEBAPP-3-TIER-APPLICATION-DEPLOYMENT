aws_region   = "eu-north-1"
project_name = "simple-pass-booking"

instance_type  = "t3.micro"
key_pair_name  = "your-pass-key"
repository_url = "https://github.com/Mickeydoe/BUS-BOOKING-WEBAPP-3-TIER-APPLICATION-DEPLOYMENT.git"

asg_min_size         = 1
asg_desired_capacity = 2
asg_max_size         = 4

db_instance_class    = "db.t4g.micro"
db_name              = "passbooking"
db_username          = "passadmin"
db_allocated_storage = 20
